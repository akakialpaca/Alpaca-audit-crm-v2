# Supabase (get from: https://supabase.com/dashboard -> Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (get from: https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# App config
NEXT_PUBLIC_SITE_URL=https://audits.alpaca.ge
ADMIN_FROM_EMAIL=noreply@audits.alpaca.ge
ADMIN_EMAIL=akaki@alpaca.ge

# Used only when running: npx tsx scripts/seed-admin.ts
FIRST_ADMIN_PASSWORD=your-secure-password
